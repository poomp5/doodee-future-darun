generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  name          String?
  points        Int       @default(0)
  Account       Account[]
  Session       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model activities {
  id                     Int                      @id @default(autoincrement())
  title                  String                   @db.VarChar(500)
  description            String?
  image_url              String?
  location               String?                  @db.VarChar(500)
  start_date             DateTime?                @db.Date
  end_date               DateTime?                @db.Date
  category               String?                  @default("general") @db.VarChar(100)
  max_participants       Int?
  is_active              Boolean?                 @default(true)
  display_order          Int?                     @default(0)
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  subcategory            String?                  @db.VarChar(100)
  source                 String?                  @default("other") @db.VarChar(50)
  link_url               String?
  deadline               DateTime?                @db.Date
  price                  Decimal?                 @default(0) @db.Decimal(10, 2)
  activity_tags          activity_tags[]
  user_viewed_activities user_viewed_activities[]

  @@index([category], map: "idx_activities_category")
  @@index([display_order], map: "idx_activities_display_order")
  @@index([is_active], map: "idx_activities_is_active")
  @@index([start_date], map: "idx_activities_start_date")
}

model categories {
  id              Int             @id @default(autoincrement())
  group_key       String          @db.VarChar(50)
  value           String          @unique @db.VarChar(100)
  label           String          @db.VarChar(100)
  display_order   Int?            @default(0)
  is_active       Boolean?        @default(true)
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?       @default(now()) @db.Timestamptz(6)
  category_groups category_groups @relation(fields: [group_key], references: [key], onDelete: Cascade, onUpdate: NoAction)

  @@index([display_order], map: "idx_categories_display_order")
  @@index([group_key], map: "idx_categories_group_key")
}

model category_groups {
  id            Int          @id @default(autoincrement())
  key           String       @unique @db.VarChar(50)
  label         String       @db.VarChar(100)
  icon          String?      @default("Layers") @db.VarChar(50)
  display_order Int?         @default(0)
  is_active     Boolean?     @default(true)
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?    @default(now()) @db.Timestamptz(6)
  categories    categories[]

  @@index([display_order], map: "idx_category_groups_display_order")
}

model courses {
  id                  Int                   @id @default(autoincrement())
  title               String                @db.VarChar(500)
  description         String?
  image_url           String?
  price               Decimal?              @default(0) @db.Decimal(10, 2)
  category            String?               @default("general") @db.VarChar(100)
  duration            String?               @db.VarChar(100)
  instructor          String?               @db.VarChar(255)
  is_active           Boolean?              @default(true)
  display_order       Int?                  @default(0)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  subcategory         String?               @default("") @db.VarChar(100)
  source              String?               @default("other") @db.VarChar(50)
  link_url            String?               @default("")
  deadline            DateTime?             @db.Date
  max_participants    Int?
  course_tags         course_tags[]
  points_courses      points_courses[]
  user_viewed_courses user_viewed_courses[]

  @@index([category], map: "idx_courses_category")
  @@index([display_order], map: "idx_courses_display_order")
  @@index([is_active], map: "idx_courses_is_active")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model point_activities {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String    @db.Uuid
  activity_type        String
  activity_description String?
  points_awarded       Int
  status               String?   @default("pending")
  metadata             Json?
  completed_at         DateTime? @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  users                users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_point_activities_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model point_history {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String    @db.Uuid
  action_type        String
  action_description String?
  points_changed     Int
  balance_before     Int
  balance_after      Int
  reference_id       String?   @db.Uuid
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_point_history_created_at")
  @@index([user_id], map: "idx_point_history_user_id")
}

model points_courses {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  description   String?
  image_url     String?
  points_cost   Int?      @default(0)
  link_url      String?
  course_id     Int?
  course_type   String?   @default("custom") @db.VarChar(50)
  is_active     Boolean?  @default(true)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  courses       courses?  @relation(fields: [course_id], references: [id], onUpdate: NoAction)
}

model points_rewards {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  description   String?
  image_url     String?
  icon          String?   @default("Gift") @db.VarChar(50)
  points_cost   Int?      @default(0)
  reward_type   String?   @default("link") @db.VarChar(50)
  reward_value  String?
  stock         Int?
  is_active     Boolean?  @default(true)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model portfolio_analysis {
  id                    BigInt      @id @default(autoincrement())
  user_id               String      @db.Uuid
  portfolio_id          String?     @db.Uuid
  strengths             Json?
  weaknesses            Json?
  recommended_faculties Json?
  subject_scores        Json?
  recommended_courses   Json?
  advice                String?
  analyzed_at           DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at            DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  file_url              String?
  portfolios            portfolios? @relation(fields: [portfolio_id], references: [id], onUpdate: NoAction)
  users                 users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([analyzed_at(sort: Desc)], map: "idx_portfolio_analysis_analyzed_at")
  @@index([portfolio_id], map: "idx_portfolio_analysis_portfolio_id")
  @@index([user_id], map: "idx_portfolio_analysis_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
