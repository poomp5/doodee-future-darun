  tag_name    String     @db.VarChar(100)
  tag_type    String     @db.VarChar(50)
  weight      Int?       @default(1)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  activities  activities @relation(fields: [activity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([activity_id], map: "idx_activity_tags_activity_id")
  @@index([tag_name], map: "idx_activity_tags_tag_name")
  @@index([tag_type], map: "idx_activity_tags_tag_type")
}

/// Tags for courses - same structure as activity tags
model course_tags {
  id         BigInt   @id @default(autoincrement())
  course_id  Int
  tag_name   String   @db.VarChar(100)
  tag_type   String   @db.VarChar(50)
  weight     Int?     @default(1)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  courses    courses  @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([course_id], map: "idx_course_tags_course_id")
  @@index([tag_name], map: "idx_course_tags_tag_name")
  @@index([tag_type], map: "idx_course_tags_tag_type")
}

/// Track what activities users have viewed for better recommendations
model user_viewed_activities {
  id          BigInt     @id @default(autoincrement())
  user_id     String     @db.Uuid
  activity_id Int
  viewed_at   DateTime   @default(now()) @db.Timestamptz(6)
  activities  activities @relation(fields: [activity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, activity_id], map: "unique_user_activity_view")
  @@index([user_id], map: "idx_user_viewed_activities_user_id")
  @@index([activity_id], map: "idx_user_viewed_activities_activity_id")
  @@index([viewed_at], map: "idx_user_viewed_activities_viewed_at")
}

/// Track what courses users have viewed
model user_viewed_courses {
  id        BigInt   @id @default(autoincrement())
  user_id   String   @db.Uuid
  course_id Int
  viewed_at DateTime @default(now()) @db.Timestamptz(6)
  courses   courses  @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, course_id], map: "unique_user_course_view")
  @@index([user_id], map: "idx_user_viewed_courses_user_id")
  @@index([course_id], map: "idx_user_viewed_courses_course_id")
  @@index([viewed_at], map: "idx_user_viewed_courses_viewed_at")
}

/// User recommendation preferences - allows users to tune their recommendations
model user_recommendation_preferences {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                   String    @unique @db.Uuid
  prefer_online             Boolean?  @default(false)
  prefer_onsite             Boolean?  @default(true)
  prefer_free               Boolean?  @default(false)
  max_price                 Decimal?  @db.Decimal(10, 2)
  preferred_difficulty      String?   @db.VarChar(50)
  exclude_categories        Json?
  boost_categories          Json?
  notification_frequency    String?   @default("weekly") @db.VarChar(50)
  last_recommendation_shown DateTime? @db.Timestamptz(6)
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @db.Timestamptz(6)
  users                     users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_user_recommendation_prefs_user_id")
}

model schools {
  school_id   String   @id @db.VarChar(20)
  school_name String
  province    String?
  district    String?
  school_type String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([school_name], map: "idx_schools_name")
  @@index([province], map: "idx_schools_province")
}

// ─── TCAS Calculator ────────────────────────────────────────────────────────
// Models for TCAS admission score calculator feature

/// Score weights for each program's admission criteria
model tcas_score_weights {
  id           Int      @id @default(autoincrement())
  program_id   Int
  subject_code String   @db.VarChar(20) // e.g., "TGAT1", "A_MATH1", "TPAT3"
  weight       Decimal  @db.Decimal(5, 4) // e.g., 0.3000 for 30%
  min_score    Decimal? @db.Decimal(5, 2) // minimum required score
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  programs     programs @relation(fields: [program_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([program_id, subject_code])
  @@index([program_id], map: "idx_tcas_score_weights_program_id")
  @@index([subject_code], map: "idx_tcas_score_weights_subject_code")
}

/// Historical cutoff scores for each program by year and round
model tcas_cutoff_history {
  id         Int      @id @default(autoincrement())
  program_id Int
  year       Int // e.g., 2568, 2567
  round      Int // 1-4 (TCAS rounds)
  min_score  Decimal  @db.Decimal(7, 2) // minimum score accepted
  max_score  Decimal? @db.Decimal(7, 2) // highest score
  avg_score  Decimal? @db.Decimal(7, 2) // average score
  seats      Int? // number of seats available
  applicants Int? // number of applicants
  created_at DateTime @default(now()) @db.Timestamptz(6)
  programs   programs @relation(fields: [program_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([program_id, year, round])
  @@index([program_id], map: "idx_tcas_cutoff_history_program_id")
  @@index([year], map: "idx_tcas_cutoff_history_year")
  @@index([round], map: "idx_tcas_cutoff_history_round")
}

/// User's calculator history and saved calculations
model user_calculator_history {
  id           Int      @id @default(autoincrement())
  user_id      String   @db.Uuid
  scores       Json // User's input scores { TGAT1: 80, TGAT2: 75, ... }
  results      Json // Calculation results
  program_type Int // 1-4 (calculation program type)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  users        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_user_calculator_history_user_id")
  @@index([created_at(sort: Desc)], map: "idx_user_calculator_history_created_at")
}

// ─── Blog System ────────────────────────────────────────────────────────────
// Multi-language blog with categories and tags

model blog_posts {
  id             Int       @id @default(autoincrement())
  slug           String    @unique @db.VarChar(255)
  author_id      String    @db.Uuid
  status         String    @default("draft") @db.VarChar(20) // draft, published, archived
  featured_image String?
  view_count     Int?      @default(0)
  is_featured    Boolean?  @default(false)
  published_at   DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  author       users                    @relation(fields: [author_id], references: [id], onDelete: Cascade)
  translations blog_post_translations[]
  categories   blog_post_categories[]
  tags         blog_post_tags[]

  @@index([status], map: "idx_blog_posts_status")
  @@index([published_at(sort: Desc)], map: "idx_blog_posts_published_at")
  @@index([slug], map: "idx_blog_posts_slug")
}

model blog_post_translations {
  id               Int     @id @default(autoincrement())
  post_id          Int
  locale           String  @db.VarChar(5) // th, en
  title            String  @db.VarChar(500)
  excerpt          String? @db.VarChar(1000)
  content          String // Markdown/HTML
  meta_title       String? @db.VarChar(100)
  meta_description String? @db.VarChar(300)

  post blog_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, locale])
}

model blog_categories {
  id            Int      @id @default(autoincrement())
  slug          String   @unique @db.VarChar(100)
  icon          String?  @default("Folder") @db.VarChar(50)
  color         String?  @db.VarChar(20)
  display_order Int?     @default(0)
  is_active     Boolean? @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  translations blog_category_translations[]
  posts        blog_post_categories[]
}

model blog_category_translations {
  id          Int     @id @default(autoincrement())
  category_id Int
  locale      String  @db.VarChar(5)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)

  category blog_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
}

model blog_tags {
  id         Int      @id @default(autoincrement())
  slug       String   @unique @db.VarChar(100)
  is_active  Boolean? @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  translations blog_tag_translations[]
  posts        blog_post_tags[]
}

model blog_tag_translations {
  id     Int    @id @default(autoincrement())
  tag_id Int
  locale String @db.VarChar(5)
  name   String @db.VarChar(100)

  tag blog_tags @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([tag_id, locale])
}

model blog_post_categories {
  id          Int @id @default(autoincrement())
  post_id     Int
  category_id Int

  post     blog_posts      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  category blog_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([post_id, category_id])
}

model blog_post_tags {
  id      Int @id @default(autoincrement())
  post_id Int
  tag_id  Int

  post blog_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  blog_tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([post_id, tag_id])
}
